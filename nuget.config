<?xml version="1.0" encoding="utf-8"?>
<!--
  Repo-level NuGet config. Has higher precedence than the in-submodule
  AssetRipper/nuget.config (which only declares SamboyDev — using that one
  via --configfile clobbers nuget.org and breaks restore for public packages
  like K4os.Compression.LZ4 / SharpCompress / etc.). Both feeds are declared
  here so dotnet build can resolve everything without --configfile gymnastics.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="SamboyDev" value="https://nuget.samboy.dev/v3/index.json" />
  </packageSources>
</configuration>
